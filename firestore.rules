rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    match /usuarios/{uid} {
      allow read: if request.auth != null;
      allow write: if request.auth != null && request.auth.uid == uid;
    }

    match /convites/{conviteId} {
      allow read: if request.auth != null;
      allow update: if request.auth != null;
      allow create, delete: if false;
    }

    match /corridas/{corridaId} {
      allow read, write: if request.auth != null &&
        (resource.data.passageiroId == request.auth.uid ||
         resource.data.motoristaId == request.auth.uid);
      allow create: if request.auth != null;

      match /mensagens/{msgId} {
        allow read, write: if request.auth != null && (
          get(/databases/$(database)/documents/corridas/$(corridaId)).data.passageiroId == request.auth.uid ||
          get(/databases/$(database)/documents/corridas/$(corridaId)).data.motoristaId == request.auth.uid
        );
      }
    }

    match /pagamentos/{pagamentoId} {
      allow read: if request.auth != null && resource.data.uid == request.auth.uid;
      allow create: if request.auth != null;
      allow update: if false;
    }

    match /avaliacoes/{avaliacaoId} {
      allow create: if request.auth != null
        && request.auth.uid == request.resource.data.avaliadorId;
      allow read: if request.auth != null;
      allow update, delete: if false;
    }

    match /denuncias/{denunciaId} {
      allow create: if request.auth != null
        && request.auth.uid == request.resource.data.denuncianteId;
      allow read, update, delete: if false;
    }

    match /adminLogs/{logId} {
      allow read: if request.auth != null
        && get(/databases/$(database)/documents/usuarios/$(request.auth.uid)).data.tipo == 'admin';
      allow write: if false;
    }
  }
}
